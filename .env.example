# Copy this file to .env and fill in your values
# NEVER commit .env to git

# ─── Supabase Auth ────────────────────────────────────────────────────────────
# Get these from your Supabase project → Settings → API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGc...your-anon-key...

# Get this from your Supabase project → Settings → API → JWT Settings → JWT Secret
SUPABASE_JWT_SECRET=your-jwt-secret-here

# ─── Gemini API Key (server-side) ─────────────────────────────────────────────
API_KEY=your_gemini_api_key_here

# ─── Google Places API Key (server-side) ──────────────────────────────────────
# Get one at: https://console.cloud.google.com → Enable "Places API (New)"
# Free $200/month credit covers ~6,250 searches/month
GOOGLE_PLACES_API_KEY=your_google_places_api_key_here
