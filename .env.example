# Copy this file to .env and fill in your values
# NEVER commit .env to git

# App Authentication (server-side — never use VITE_ prefix for secrets)
APP_USERNAME=your_email@example.com
APP_PASSWORD=your_secure_password_here
SESSION_SECRET=generate_a_random_32_char_string_here

# Gemini API Key (server-side)
API_KEY=your_gemini_api_key_here

# Google Places API Key (server-side) — used for real church location search
# Get one at: https://console.cloud.google.com → Enable "Places API (New)"
# Free $200/month credit covers ~6,250 searches/month
GOOGLE_PLACES_API_KEY=your_google_places_api_key_here
